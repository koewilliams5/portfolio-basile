APP_NAME="Portfolio Basile"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# ============================================================
# CONFIGURATION EMAIL (IMPORTANT pour le formulaire de contact)
# ============================================================
# Option 1 — MAILTRAP (pour tester en local, emails capturés sans être envoyés)
# Crée un compte gratuit sur https://mailtrap.io et copie les infos ici
MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=ton_username_mailtrap
MAIL_PASSWORD=ton_password_mailtrap
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="koebibasile5@gmail.com"
MAIL_FROM_NAME="Portfolio Basile"

# Option 2 — GMAIL (pour la production, envoi réel)
# Va dans ton compte Gmail > Sécurité > Mots de passe d'application
# Génère un mot de passe pour "Application mail"
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=koebibasile5@gmail.com
# MAIL_PASSWORD=ton_mot_de_passe_application_gmail
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS="koebibasile5@gmail.com"
# MAIL_FROM_NAME="Portfolio Basile"

# ============================================================
# BASE DE DONNÉES (non nécessaire pour le portfolio simple)
# ============================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=portfolio_basile
DB_USERNAME=root
DB_PASSWORD=

# Cache & Session
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
